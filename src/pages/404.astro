---
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/jpeg" href="/favicon.jpg" />
    <title>Page Not Found</title>
  </head>
  <body class="min-h-screen bg-white text-gray-900 flex items-center justify-center p-8">
    <main class="text-center">
      <h1 class="text-6xl font-bold mb-4">404</h1>
      <p class="text-xl text-gray-700 mb-8">This page doesn't exist.</p>
      <a href="/" class="underline hover:no-underline" style="color: #1e2939;">Back to home</a>
    </main>
  </body>
</html>
